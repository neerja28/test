{
  "properties": {
    "displayName": "Enforce Web App ftp state to use ftps_only or disabled",
    "policyType": "Custom",
    "mode": "All",
    "description": "Enable ftps_only or ftp disabled for Web App's enhanced security",
    "metadata": {
      "category": "App Service",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": "",
      "updatedOn": ""
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Append",
          "Disabled"
        ],
        "defaultValue": "Append"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "notContains": "functionapp",
            "field": "kind"
          },
          {
            "anyOf": [
              {
                "allOf": [
                  {
                    "exists": "true",
                    "field": "Microsoft.Web/sites/siteConfig.ftpsState"
                  },
                  {
                    "equals": "AllAllowed",
                    "field": "Microsoft.Web/sites/siteConfig.ftpsState"
                  }
                ]
              },
              {
                "allOf": [
                  {
                    "exists": "false",
                    "field": "Microsoft.Web/sites/siteConfig.ftpsState"
                  }
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": [
          {
            "field": "Microsoft.Web/sites/siteConfig.ftpsState",
            "value": "Disabled"
          }
        ]
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "78aecba0-58ac-4867-addd-67d4fe6b0513"
}