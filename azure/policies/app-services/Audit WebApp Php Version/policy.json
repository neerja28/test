{
  "properties": {
    "displayName": "Audit WebApp PHP Version EOL",
    "mode": "All",
    "description": "Periodically, newer versions are released for Php software either due to security flaws or to include additional functionality. Using a supported Php version for App Service apps is recommended in order to take advantage of security fixes, if any, and/or new functionalities of the latest version. This policy only applies to Linux apps. This policy requires you to specify a Php version that meets your requirements.",
    "metadata": {
      "category": "App Service"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "AuditIfNotExists"
      },
      "LinuxPhpEolVersions": {
        "type": "Array",
        "metadata": {
          "displayName": "Linux unsupported Php versions",
          "description": "Unsupported Php versions for App Services"
        }
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "field": "kind",
            "notContains": "functionapp"
          },
          {
            "field": "kind",
            "contains": "linux"
          },
          {
            "field": "Microsoft.Web/sites/siteConfig.linuxFxVersion",
            "contains": "PHP"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.Web/sites/config",
          "name": "web",
          "existenceCondition": {
            "field": "Microsoft.Web/sites/config/web.linuxFxVersion",
            "notIn": "[parameters('LinuxPhpEolVersions')]"
          }
        }
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "78824901-ea8e-4123-b84c-21f5d1885751"
}