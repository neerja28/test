{
    "properties": {
        "displayName": "Audit managed disks encrypted with a platform-managed key",
        "policyType": "Custom",
        "mode": "Indexed",
        "description": "Ensure that Managed disks are encrypted with PMK (Platform Managed Keys). PMK encryption is enabled by default.",
        "metadata": {
            "category": "Compute",
            "version": "3.0.0"
        },
        "parameters": {
            "effect": {
                "type": "String",
                "metadata": {
                    "displayName": "Effect",
                    "description": "Enable or disable the execution of the policy"
                },
                "allowedValues": [
                    "Audit",
                    "Deny",
                    "Disabled"
                ],
                "defaultValue": "Audit"
            }
        },
        "policyRule": {
            "if": {
                "allof": [{
                        "field": "type",
                        "equals": "Microsoft.Compute/disks"
                    },
                    {
                        "field": "Microsoft.Compute/disks/encryption.type",
                        "exists": "false"
                    }
                ]
            },
            "then": {
                "effect": "[parameters('effect')]"
            }
        }
    },
    "id": "",
    "type": "Microsoft.Authorization/policyDefinitions",
    "name": "702dd420-7fcc-42c5-afe8-4026edd20feN"
}