{
  "properties": {
    "displayName": "Enforce Azure Hybrid Benefit on VM for Windows Desktop",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Azure Hybrid Benefit is a licensing benefit that helps you to significantly reduce the costs of running your workloads in the cloud.It works by letting you use your on-premises Software Assurance-enabled Windows Server and SQL Server licenses on Azure",
    "metadata": {
      "category": "Compute",
      "version": "1.0.0",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": null,
      "updatedOn": null
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [{
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "field": "Microsoft.Compute/licenseType",
            "exists": false
          },
          {
            "field": "Microsoft.Compute/imagePublisher",
            "in": [
              "MicrosoftWindowsDesktop"
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
          ],
          "conflictEffect": "deny",
          "operations": [{
            "operation": "addOrReplace",
            "field": "Microsoft.Compute/virtualMachines/licenseType",
            "value": "Windows_Client"
          }]
        }
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "0204e3e7-d0dc-4f98-9c80-256bf3758ce8"
}