{
  "properties": {
    "displayName": "Enforce Hybrid Benefit on Azure Redhat Linux VM",
    "policyType": "Custom",
    "mode": "All",
    "description": "Azure Hybrid Benefit is a licensing benefit that helps you to significantly reduce the costs of running your workloads in the cloud.It works by letting you use your on-premises Software Assurance-enabled Redhat Linux VMs on Azure",
    "metadata": {
      "category": "Compute",
      "version": "1.0.0",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": null,
      "updatedOn": null
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [{
            "equals": "Microsoft.Compute/virtualMachines",
            "field": "type"
          },
          {
            "equals": "Linux",
            "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType"
          },
          {
            "anyOf": [{
                "exists": false,
                "field": "Microsoft.Compute/virtualMachines/licenseType"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/licenseType",
                "notEquals": "RHEL_BYOS"
              }
            ]
          },
          {
            "anyOf": [{
                "equals": "RedHat",
                "field": "Microsoft.Compute/imagePublisher"
              },
              {
                "contains": "RHEL",
                "field": "Microsoft.Compute/imageOffer"
              },
              {
                "contains": "RedHat",
                "field": "Microsoft.Compute/virtualMachines/imagePublisher"
              },
              {
                "contains": "RHEL",
                "field": "Microsoft.Compute/virtualMachines/imageOffer"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/instanceView.osName",
                "equals": "RedHat"
              }

            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
          ],
          "conflictEffect": "deny",
          "operations": [{
            "operation": "addOrReplace",
            "field": "Microsoft.Compute/virtualMachines/licenseType",
            "value": "RHEL_BYOS"
          }]
        }
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "8e51ac24-6243-4c6b-8da6-6726249a5b09"
}