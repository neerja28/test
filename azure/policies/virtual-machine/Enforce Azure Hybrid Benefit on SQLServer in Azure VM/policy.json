{
  "properties": {
    "displayName": "Enforce Azure Hybrid Benefit on SQLServer in Azure VM",
    "policyType": "Custom",
    "mode": "All",
    "description": "Azure Hybrid Benefit is a licensing benefit that helps you to significantly reduce the costs of running your workloads in the cloud. It works by letting you use your on-premises Software Assurance-enabled Windows Server and SQL Server licenses on Azure",
    "metadata": {
      "category": "SQL",
      "version": "1.0.0",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": null,
      "updatedOn": null
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "AuditIfNotExists",
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [{
          "field": "type",
          "equals": "Microsoft.SqlVirtualMachine/SqlVirtualMachines"
        }]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.SqlVirtualMachine/sqlVirtualMachines",
          "evaluationDelay": "AfterProvisioning",
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/b24988ac-6180-42a0-ab88-20f7382dd24c"
          ],
          "name": "[field('name')]",
          "existenceCondition": {
            "allOf": [{
                "field": "Microsoft.SqlVirtualMachine/SqlVirtualMachines/sqlServerLicenseType",
                "in": [
                  "AHUB",
                  "DR"
                ]
              },
              {
                "anyOf": [{
                    "field": "Microsoft.SqlVirtualMachine/SqlVirtualMachines/sqlImageSku",
                    "equals": "Standard"
                  },
                  {
                    "field": "Microsoft.SqlVirtualMachine/SqlVirtualMachines/sqlImageSku",
                    "equals": "Enterprise"
                  }
                ]
              },
              {
                "field": "Microsoft.SqlVirtualMachine/SqlVirtualMachines/sqlImageOffer",
                "contains": "-WS"
              }
            ]
          },
          "deployment": {
            "properties": {
              "mode": "incremental",
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "sqlHostName": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "virtualMachineId": {
                    "type": "string"
                  }
                },
                "resources": [{
                  "name": "[parameters('sqlHostName')]",
                  "type": "Microsoft.SqlVirtualMachine/sqlVirtualMachines",
                  "apiVersion": "2022-07-01-preview",
                  "location": "[parameters('location')]",
                  "properties": {
                    "virtualMachineResourceId": "[parameters('virtualMachineId')]",
                    "sqlServerLicenseType": "AHUB"
                  }
                }]
              },
              "parameters": {
                "sqlHostName": {
                  "value": "[field('name')]"
                },
                "location": {
                  "value": "[field('location')]"
                },
                "virtualMachineId": {
                  "value": "[field('Microsoft.SqlVirtualMachine/sqlVirtualMachines/virtualMachineResourceId')]"
                }
              }
            }
          }
        }
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "29501156-4859-4976-ac31-701db332ce4e"
}