{
  "properties": {
    "displayName": "Enforce Azure Hybrid Benefit on VM for Windows Server",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Azure Hybrid Benefit is a licensing benefit that helps you to significantly reduce the costs of running your workloads in the cloud.It works by letting you use your on-premises Software Assurance-enabled Windows Server and SQL Server licenses on Azure",
    "metadata": {
      "category": "Compute",
      "version": "1.0.0",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": null,
      "updatedOn": null
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [{
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "anyOf": [{
                "field": "Microsoft.Compute/licenseType",
                "exists": false
              },
              {
                "field": "Microsoft.Compute/licenseType",
                "notEquals": "Windows_Server"
              }
            ]
          },
          {
            "allOf": [{
                "anyOf": [{
                    "field": "Microsoft.Compute/imagePublisher",
                    "equals": "MicrosoftWindowsServer"
                  },
                  {
                    "field": "Microsoft.Compute/imagePublisher",
                    "contains": "Windows"
                  },
                  {
                    "field": "Microsoft.Compute/imagePublisher",
                    "contains": "MicrosoftSQLServer"
                  },
                  {
                    "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType",
                    "equals": "Windows"
                  }
                ]
              },
              {
                "not": {
                  "field": "Microsoft.Compute/imagePublisher",
                  "equals": "MicrosoftWindowsDesktop"
                }
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/microsoft.authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
          ],
          "conflictEffect": "deny",
          "operations": [{
            "operation": "addOrReplace",
            "field": "Microsoft.Compute/virtualMachines/licenseType",
            "value": "Windows_Server"
          }]
        }
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "b8d0c59b-305f-48ac-8d84-6b46aa8b8397"
}