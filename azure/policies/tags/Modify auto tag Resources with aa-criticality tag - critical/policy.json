    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "[concat('tags[',parameters('tagName'), ']')]",
            "in": "[parameters('tagValue')]"
          },
          {
            "field": "[concat('tags[',parameters('criticalityTagName'), ']')]",
            "notEquals": "[parameters('criticalityTagValue')]"
          }
        ]
      },
      "then": {
        "effect": "modify",
        "details": {
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/4a9ae827-6dc8-4573-8ac7-8239d42aa03f"
          ],
          "conflictEffect": "deny",
          "operations": [
            {
              "operation": "addOrReplace",
              "field": "[concat('tags[',parameters('criticalityTagName'), ']')]",
              "value": "[parameters('criticalityTagValue')]"
            }
          ]
        }
      }
    }
