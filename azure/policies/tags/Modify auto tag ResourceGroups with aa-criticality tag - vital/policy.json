          "WANLAN",
          "WeatherDD",
          "WeatherSS",
          "WebAppDef"
        ]
      },
      "criticalityTagName": {
        "type": "String",
        "metadata": {
          "displayName": "Criticality Tag Name",
          "description": "Name of the tag, such as 'environment'"
        },
        "defaultValue": "aa-criticality"
      },
      "criticalityTagValue": {
        "type": "String",
        "metadata": {
          "displayName": "Criticality Tag Value",
          "description": "Value of the tag, such as 'Vital'"
        },
        "defaultValue": "vital"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Resources/subscriptions/resourceGroups"
          },
          {
            "field": "[concat('tags[',parameters('tagName'), ']')]",
            "in": "[parameters('tagValue')]"
          },
          {
            "field": "[concat('tags[',parameters('criticalityTagName'), ']')]",
            "notEquals": "[parameters('criticalityTagValue')]"
          }
        ]
      },
      "then": {
        "effect": "modify",
        "details": {
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/4a9ae827-6dc8-4573-8ac7-8239d42aa03f"
          ],
          "operations": [
            {
              "operation": "addOrReplace",
              "field": "[concat('tags[',parameters('criticalityTagName'), ']')]",
              "value": "[parameters('criticalityTagValue')]"
            }
          ]
        }
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "d4f895e8-b408-473f-8bcd-818d2341ed29"
}