{
  "properties": {
    "displayName": "Auto Tag Vital Resource Groups with aa-criticality Tag",
    "policyType": "Custom",
    "mode": "All",
    "description": "Adds aa-criticality tag and its corresponding value as per Archer record to Resource group.",
    "metadata": {},
    "parameters": {
      "tagName": {
        "type": "String",
        "metadata": {
          "displayName": "Tag Name",
          "description": "Name of the tag, such as 'environment'"
        },
        "defaultValue": "aa-app-shortname"
      },
      "tagValue": {
        "type": "Array",
        "metadata": {
          "displayName": "Tag Value",
          "description": "Value of the tag, such as 'production'"
        },
        "defaultValue": [
          "AACom",
          "AAFltPlan",
          "AAHub",
          "ACARS",
          "AD",
