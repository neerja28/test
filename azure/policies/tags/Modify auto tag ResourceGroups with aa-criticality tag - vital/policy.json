          "RGNOpsSte",
          "RGNVrtHost",
          "RGNWthrSys",
          "RtrvResSvc",
          "SAFEComSvc",
          "SafeLinMOC",
          "SCEPTRE",
          "SecretsMgt",
          "SonusIntl",
          "SonusSBC",
          "SPEClient",
