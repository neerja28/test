{
    "properties": {
      "displayName": "Enforce Function App should only be accessible over HTTPS",
      "policyType": "Custom",
      "mode": "Indexed",
      "description": "Use of HTTPS ensures server/service authentication and protects data in transit from network layer eavesdropping attacks.",
      "metadata": {
        "category": "App Service",
        "createdBy": "",
        "createdOn": "",
        "updatedBy": "",
        "updatedOn": ""
      },
      "parameters": {
        "effect": {
          "type": "String",
          "metadata": {
            "displayName": "Effect",
            "description": "Enable or disable the execution of the policy"
          },
          "allowedValues": [
            "Append",
            "Disabled"
          ],
          "defaultValue": "Append"
        }
      },
      "policyRule": {
        "if": {
          "allOf": [
            {
              "field": "type",
              "equals": "Microsoft.Web/sites"
            },
            {
              "like": "functionapp*",
              "field": "kind"
            },
            {
              "anyOf": [
                {
                  "allOf": [
                    {
                      "exists": "true",
                      "field": "Microsoft.Web/sites/httpsOnly"
                    },
                    {
                      "notEquals": "true",
                      "field": "Microsoft.Web/sites/httpsOnly"
                    }
                  ]
                },
                {
                  "allOf": [
                    {
                      "exists": "false",
                      "field": "Microsoft.Web/sites/httpsOnly"
                    }
                  ]
                }
              ]
            }
          ]
        },
        "then": {
          "effect": "[parameters('effect')]",
          "details": [
            {
              "field": "Microsoft.Web/sites/httpsOnly",
              "value": true
            }
          ]
        }
      }
    },
    "id": "",
    "type": "Microsoft.Authorization/policyDefinitions",
    "name": "49e7c433-1be9-4b57-8878-374b5cc270a6"
}