{
  "properties": {
    "displayName": "Enforce Function App only use TLS version >=1.2",
    "policyType": "Custom",
    "mode": "All",
    "description": "Setting minimal TLS version to 1.2 improves security by ensuring your WebApp can only be accessed from clients using TLS 1.2. Using versions of TLS less than 1.2 is not recommended since they have well documented security vulnerabilities.",
    "metadata": {
      "category": "App Service",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": "",
      "updatedOn": ""
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [{
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "like": "functionapp*",
            "field": "kind"
          },
          {
            "allOf": [{
                "field": "Microsoft.Web/sites/siteConfig.minTlsVersion",
                "exists": "true"
              },
              {
                "field": "Microsoft.Web/sites/siteConfig.minTlsVersion",
                "notEquals": "1.2"
              }
            ]
          },
          {
            "field": "Microsoft.Web/sites/siteConfig.minTlsVersion",
            "exists": "true"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "bf055862-3c7c-4a97-b7cc-2b17b3334d90"
}