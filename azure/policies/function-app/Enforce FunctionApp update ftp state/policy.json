{
  "properties": {
    "displayName": "Enforce Function App Update ftp state to use ftps_only or disabled",
    "policyType": "Custom",
    "mode": "All",
    "description": "Enable ftps_only or ftp disabled for Web App's enhanced security",
    "metadata": {
      "category": "App Service",
      "createdBy": "",
      "createdOn": "",
      "updatedBy": "",
      "updatedOn": ""
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites/config"
          },
          {
            "like": "functionapp*",
            "field": "kind"
          },
          {
            "allOf": [
              {
                "exists": "true",
                "field": "Microsoft.Web/sites/config/ftpsState"
              },
              {
                "field": "Microsoft.Web/sites/config/ftpsState",
                "notIn": [
                  "FtpsOnly",
                  "Disabled"
                ]
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "adfe766d-7f8c-4727-9d16-b6a73c34c161" 
}