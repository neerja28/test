{
  "properties": {
    "displayName": "Kubernetes Services should be upgraded to acceptable AKS version",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Upgrade your Kubernetes service cluster to a Latest Kubernetes version to protect against known vulnerabilities in your current Kubernetes version. Acceptable Versions are as follows: Latest Version, lets call it version N and can go upto N-2.",
    "metadata": {
      "category": "Security Center"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "allowedKubernetesVersions": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed Kubernetes Versions",
          "description": "The list of allowed Kubernetes versions for AKS clusters."
        },
        "defaultValue": [
          "1.30",
          "1.30.*",
          "1.29",
          "1.29.*",
          "1.28",
          "1.28.*"
        ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.ContainerService/managedClusters"
          },
          {
            "field": "Microsoft.ContainerService/managedClusters/kubernetesVersion",
            "notIn": "[parameters('allowedKubernetesVersions')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  },
  "id": "",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "3e1d58f6-82b9-4d4d-9bb2-f88857456e6b"
}